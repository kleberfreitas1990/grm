# ═══════════════════════════════════════════════════════════════════════════════
# Configuração do TiDB Cloud para persistência de dados no Streamlit Cloud.
# ═══════════════════════════════════════════════════════════════════════════════
#
# PARA DEPLOY NO STREAMLIT CLOUD:
# 1. Crie um cluster gratuito em https://tidbcloud.com
# 2. Copie os dados de conexão (host, porta, usuário, senha, nome do banco)
# 3. Cole o conteúdo deste arquivo em "Edit Secrets" no dashboard do Streamlit Cloud
#    (substituindo os valores pelos seus dados reais)
# 4. Nunca envie o arquivo secrets.toml real ao repositório.
#
# ─── Configuração do TiDB Cloud ───────────────────────────────────────────────
[connections.tidb]
dialect = "mysql"
host = "<SEU_HOST_TIDB>"
port = 4000
database = "grm"
username = "<SEU_USUARIO_TIDB>"
password = "<SUA_SENHA_TIDB>"

# ═══════════════════════════════════════════════════════════════════════════════
# As senhas dos usuários internos (compras e almoxarifado) são gerenciadas
# automaticamente pela tabela 'usuarios' no banco de dados.
# A senha padrão é Grm@2026 para ambas as contas.
# ═══════════════════════════════════════════════════════════════════════════════
